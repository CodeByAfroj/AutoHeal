# ================================
# AutoHeal 2.0 — Environment Config
# ================================

# GitHub OAuth App
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/autoheal?retryWrites=true&w=majority

# JWT Secret (any random string, 32+ chars recommended)
JWT_SECRET=

# Encryption Key (64 hex chars = 32 bytes for AES-256-GCM)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Groq API Key (primary AI — free at https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini API Key (optional fallback — https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ngrok URL (update after running: ngrok http 8000)
NGROK_URL=

# Webhook Secret (any random string)
WEBHOOK_SECRET=autoheal_webhook_secret

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Server Port
PORT=8000
