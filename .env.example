# AutoHeal 2.0 — Environment Variables
# Copy this file to backend/.env and fill in your values

# GitHub OAuth App (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# MongoDB
MONGODB_URI=mongodb://localhost:27017/autoheal

# JWT Secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change_this_to_a_random_64_char_hex_string

# Encryption Key for tokens (exactly 32 hex chars = 16 bytes for AES-256)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Kestra API URL
KESTRA_API_URL=http://localhost:8080

# ngrok public URL (run: ngrok http 8000)
NGROK_URL=https://your-subdomain.ngrok-free.app

# Gemini API Key (get at: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Webhook secret for GitHub signature verification
WEBHOOK_SECRET=your_webhook_secret

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Server port
PORT=8000
