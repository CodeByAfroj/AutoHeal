# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# MongoDB
MONGODB_URI=mongodb://localhost:27017/autoheal

# JWT Secret (generate a random 64-char hex string)
JWT_SECRET=your_jwt_secret_here

# Token Encryption Key (exactly 32 hex chars for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Kestra
KESTRA_API_URL=http://localhost:8080

# ngrok public URL (no trailing slash)
NGROK_URL=https://your-subdomain.ngrok-free.app

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Webhook secret for signature verification
WEBHOOK_SECRET=your_webhook_secret

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Server port
PORT=8000
